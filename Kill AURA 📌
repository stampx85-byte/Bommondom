game:GetService("RunService").Heartbeat:Connect(function()
    if not antiWarpEnabled then return end
    local char = plr.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    
    if hrp and hum and hum.Health > 0 then
        if lastValidPos and (hrp.Position - lastValidPos.Position).Magnitude > 20 then
            hrp.CFrame = lastValidPos 
            hrp.Velocity = Vector3.zero 
            game:GetService("ReplicatedStorage").GetItemBack:FireServer()
            Notification.new({Title = "Anti-Warp Active", Description = "Warp detected! Item claimed.", Duration = 2})
        else 
            lastValidPos = hrp.CFrame 
        end
        
        for _, obj in ipairs(hrp:GetChildren()) do 
            if obj:IsA("BodyVelocity") or obj:IsA("BodyGyro") then 
                obj:Destroy() 
            end 
        end
        
        if hrp.Anchored then hrp.Anchored = false end
    end
end)

--// --- [ SYSTEM FUNCTIONS: ANTI-CRASH ] --- //--
local function applyAntiCrash(p)
    if not antiCrashEnabled then return end
    local plrgui = p:WaitForChild("PlayerGui")
    
    local function cleanGui(gui)
        if antiCrashEnabled and gui.Name == "Announcement" then
            gui:Destroy()
        end
    end

    for _, g in ipairs(plrgui:GetChildren()) do cleanGui(g) end
    plrgui.ChildAdded:Connect(cleanGui)
end

