local function pullAllGuns()
    for i = 1, 10 do
        toolStorage:FireServer("Get", "Gun")
    end
end

local function stashAllGuns()
    for _, item in ipairs(plr.Backpack:GetChildren()) do
        if item.Name == "Gun" then toolStorage:FireServer("Save", "Gun") end
    end
    if plr.Character then
        for _, item in ipairs(plr.Character:GetChildren()) do
            if item.Name == "Gun" then toolStorage:FireServer("Save", "Gun") end
        end
    end
end

-- อัปเกรดระบบยิง: Hyper-Burst Accuracy
local function fireGunAt(targetPart)
    if not targetPart or not plr.Character then return end
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    local root = plr.Character:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    local guns = {}
    for _, item in ipairs(plr.Backpack:GetChildren()) do
        if item.Name == "Gun" and item:FindFirstChild("shot") then
            table.insert(guns, item)
        end
    end

    for _, gun in ipairs(guns) do
        if not (killAllEnabled or targetLockEnabled or killAuraEnabled) then break end
        
        hum:EquipTool(gun)
        
        -- ปรับปรุง Prediction ให้คมกว่าเดิม (คำนวณตาม Velocity จริง)
        local aimPos = targetPart.Position + (targetPart.Velocity * 0.11)
        
        -- Omni-Warp Grip (วาร์ปกระบอกปืนไปจ่อเป้าหมายในระยะเผาขน)
        local offset = Vector3.new(math.random(-2,2), math.random(2,6), math.random(-2,2))
        gun.Grip = CFrame.new((aimPos + offset) - root.Position) * CFrame.Angles(math.rad(math.random(-360,360)), math.rad(math.random(-360,360)), 0)

        -- สร้าง Hitbox ที่แม่นยำสูง
        local hb = Instance.new("Part")
        hb.Size = Vector3.new(7, 7, 7)
        hb.Transparency = 1
        hb.CanCollide = false
        hb.Anchored = true
        hb.CFrame = CFrame.new(aimPos)
        hb.Parent = workspace
        game:GetService("Debris"):AddItem(hb, 0.005)

        -- อัดคำสั่งยิงเบิ้ล (Triple Shot Burst) ใน 1 Frame
        for i = 1, 3 do
            gun.shot:FireServer(hb.Position)
        end
        
        task.wait(0.005) -- ค่าความเสถียรสูงสุด (ไม่เด้ง ไม่หลุด)
        hum:UnequipTools()
    end
end

local function findAndClick(targetPos)
    for _, v in ipairs(game.Workspace:GetDescendants()) do
        if v:IsA("ClickDetector") and v.Parent:IsA("BasePart") then
            if (v.Parent.Position - targetPos).Magnitude < 15 then
                if fireclickdetector then fireclickdetector(v) return true end
            end
        end
    end
    return false
end

