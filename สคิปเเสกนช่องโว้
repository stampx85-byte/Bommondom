-- [FACTORY] ฟังก์ชันสร้างรายการข้อมูล (พร้อมปุ่มก๊อปปี้)
local function AddItem(name, typeInfo, modelInfo, details, fullPath)
    local Card = Instance.new("Frame")
    Card.Size = UDim2.new(1, -5, 0, 65)
    Card.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Card.Parent = ContentFrame
    Card.BorderSizePixel = 0

    local Accent = Instance.new("Frame")
    Accent.Size = UDim2.new(0, 3, 1, 0)
    Accent.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    Accent.BorderSizePixel = 0
    Accent.Parent = Card

    local NameLabel = Instance.new("TextLabel")
    NameLabel.Text = "[" .. typeInfo .. "] " .. name
    NameLabel.Size = UDim2.new(1, -80, 0, 20)
    NameLabel.Position = UDim2.new(0, 10, 0, 5)
    NameLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
    NameLabel.Font = Enum.Font.GothamBold
    NameLabel.TextSize = 11
    NameLabel.TextXAlignment = Enum.TextXAlignment.Left
    NameLabel.BackgroundTransparency = 1
    NameLabel.Parent = Card

    local DescLabel = Instance.new("TextLabel")
    DescLabel.Text = "MOD: " .. modelInfo .. " | " .. details
    DescLabel.Size = UDim2.new(1, -15, 0, 30)
    DescLabel.Position = UDim2.new(0, 10, 0, 25)
    DescLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
    DescLabel.Font = Enum.Font.Gotham
    DescLabel.TextSize = 9
    DescLabel.TextXAlignment = Enum.TextXAlignment.Left
    DescLabel.TextWrapped = true
    DescLabel.BackgroundTransparency = 1
    DescLabel.Parent = Card

    -- [COPY_BUTTON] ปุ่มก๊อปปี้เส้นทางไฟล์
    local CopyBtn = Instance.new("TextButton")
    CopyBtn.Text = "COPY"
    CopyBtn.Size = UDim2.new(0, 50, 0, 20)
    CopyBtn.Position = UDim2.new(1, -55, 0, 5)
    CopyBtn.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
    CopyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    CopyBtn.Font = Enum.Font.GothamBold
    CopyBtn.TextSize = 9
    CopyBtn.Parent = Card

    CopyBtn.MouseButton1Click:Connect(function()
        setclipboard(tostring(fullPath))
        CopyBtn.Text = "DONE!"
        Notify("PATH COPIED TO CLIPBOARD")
        task.wait(1)
        CopyBtn.Text = "COPY"
    end)

    ContentFrame.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
end

-- [LOGIC] ระบบคลิกเลือกวัตถุและแสกน
SelectBtn.MouseButton1Click:Connect(function()
    Notify("SELECTING... CLICK ON A PART")
    local Conn; Conn = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local target = game.Players.LocalPlayer:GetMouse().Target
            if target then
                for _, v in pairs(ContentFrame:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
                AddItem(target.Name, "OBJ", target.ClassName, "Found in workspace", target:GetFullName())
                for _, child in pairs(target:GetDescendants()) do
                    if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") or child:IsA("Script") then
                        AddItem(child.Name, "FILE", child.ClassName, "Internal Component", child:GetFullName())
                    end
                end
            end
            Conn:Disconnect()
        end
    end)
end)

ScanBtn.MouseButton1Click:Connect(function()
    Notify("SCANNING GLOBAL REMOTES")
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("RemoteEvent") then AddItem(v.Name, "REMOTE", "Event", "Network Trigger", v:GetFullName()) end
    end
end)

Notify("SKY SOUND V2 READY")
