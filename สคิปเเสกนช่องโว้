-- [HELPER] ระบบแจ้งเตือน (Notifications)
local function Notify(text)
    local Notif = Instance.new("TextLabel")
    Notif.Size = UDim2.new(0, 250, 0, 35)
    Notif.Position = UDim2.new(0.5, -125, 0.85, 0)
    Notif.BackgroundColor3 = Color3.fromRGB(15, 0, 0)
    Notif.TextColor3 = Color3.fromRGB(255, 50, 50)
    Notif.Text = ">> " .. text .. " <<"
    Notif.Font = Enum.Font.SpecialElite
    Notif.TextSize = 14
    Notif.BorderSizePixel = 0
    Notif.Parent = ScreenGui
    Instance.new("UIStroke", Notif).Color = Color3.fromRGB(255, 0, 0)

    TweenService:Create(Notif, TweenInfo.new(0.4), {Position = UDim2.new(0.5, -125, 0.8, 0)}):Play()
    task.delay(2, function()
        TweenService:Create(Notif, TweenInfo.new(0.5), {TextTransparency = 1, BackgroundTransparency = 1}):Play()
        task.wait(0.5); Notif:Destroy()
    end)
end

