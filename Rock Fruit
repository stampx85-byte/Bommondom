-- ระบบ Auto Farm Chest + Kill Villain
task.spawn(function()
    while task.wait() do
        if _G.AutoChest then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local char = lp.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                
                local chest = nil
                local minDist = math.huge
                for _, v in pairs(game.Workspace:GetDescendants()) do
                    if v.Name == "ChestRef" and v:IsA("BasePart") then
                        local dist = (hrp.Position - v.Position).Magnitude
                        if dist < minDist then
                            minDist = dist
                            chest = v
                        end
                    end
                end

                if chest and hrp then
                    local nearbyVillain = nil
                    for _, m in pairs(game.Workspace.Mob:GetChildren()) do
                        if m.Name == "Villain" and m:FindFirstChild("Humanoid") and m.Humanoid.Health > 0 and m:FindFirstChild("HumanoidRootPart") then
                            if (m.HumanoidRootPart.Position - chest.Position).Magnitude < 50 then
                                nearbyVillain = m
                                break
                            end
                        end
                    end

                    if nearbyVillain then
                        hrp.CFrame = nearbyVillain.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2)
                        local weapon = char:FindFirstChild(_G.SelectedWeapon) or lp.Backpack:FindFirstChild(_G.SelectedWeapon)
                        if weapon then 
                            if weapon.Parent ~= char then char.Humanoid:EquipTool(weapon) end
                            weapon:Activate() 
                        end
                    else
                        hrp.CFrame = chest.CFrame
                        task.wait(0.1)
                        local p = chest:FindFirstChildOfClass("ProximityPrompt") or chest:FindFirstChildWhichIsA("ProximityPrompt", true)
                        if p then
                            p.MaxActivationDistance = 9999
                            p.HoldDuration = 0
                            p.RequiresLineOfSight = false
                            p:InputHoldBegin()
                            task.wait(0.2)
                            p:InputHoldEnd()
                        end
                        
                        local hud = lp.PlayerGui:FindFirstChild("HUD")
                        local rewards = hud and hud:FindFirstChild("Rewards")
                        local chestCard = rewards and rewards:FindFirstChild("ChestCard")
                        
                        while chestCard and chestCard.Visible == true do
                            for i = 1, 5 do
                                pcall(function()
                                    local slot = chestCard.Inset:FindFirstChild(tostring(i))
                                    if slot and slot.Frame and slot.Frame.Button then
                                        local btn = slot.Frame.Button
                                        firesignal(btn.MouseButton1Click)
                                        firesignal(btn.MouseButton1Down)
                                        firesignal(btn.Activated)
                                    end
                                end)
                            end
                            task.wait(0.1)
                            if not _G.AutoChest then break end
                        end
                    end
                end
            end)
        end
    end
end)

-- ระบบวาร์ปฟาร์มปกติ
task.spawn(function()
    while task.wait() do
        if (_G.AutoFarm and _G.FarmType ~= "None") or (_G.AutoDunFarm and _G.DunFarmType ~= "None") or (_G.AutoFarmArea) then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local currentFolder = _G.AutoDunFarm and DunMobFolder or MobFolder
                local currentType = _G.AutoDunFarm and _G.DunFarmType or _G.FarmType
                local mainTarget = nil

                for _, v in pairs(currentFolder:GetChildren()) do
                    if (_G.AutoFarmArea or v.Name == currentType) and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                        if v.Humanoid.Health >= v.Humanoid.MaxHealth then
                            hrp.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 0, 1)
                            local weapon = lp.Character:FindFirstChild(_G.SelectedWeapon) or lp.Backpack:FindFirstChild(_G.SelectedWeapon)
                            if weapon then 
                                if weapon.Parent ~= lp.Character then lp.Character.Humanoid:EquipTool(weapon) end
                                weapon:Activate() 
                            end
                            task.wait(0.05)
                        end
                        if not mainTarget then mainTarget = v end
                    end
                end

                if mainTarget and mainTarget:FindFirstChild("HumanoidRootPart") then
                    local mobPos = mainTarget.HumanoidRootPart.Position
                    hrp.CFrame = CFrame.lookAt(mobPos + Vector3.new(0, _G.DistanceAbove, 0), mobPos)
                end
            end)
        end
    end
end)

-- ระบบ Auto Click Items
task.spawn(function()
    while task.wait() do
        if _G.AutoBoneSatoru or _G.AutoGreenCells then
            pcall(function()
                local char = game.Players.LocalPlayer.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                local targetClickPos = _G.AutoBoneSatoru and Vector3.new(1415.49146, 12.8422089, 1080.62158) or Vector3.new(-159.092834, 9.08454895, -27.5221729)
                
                if hum.FloorMaterial ~= Enum.Material.Air then
                    hrp.Anchored = true
                    for _, v in pairs(game.Workspace:GetDescendants()) do
                        if v:IsA("ClickDetector") and (v.Parent:IsA("BasePart") or v.Parent:IsA("Model")) then
                            if (v.Parent:GetPivot().Position - targetClickPos).Magnitude < 15 then
                                fireclickdetector(v)
                            end
                        end
                    end
                else
                    hrp.Anchored = false
                end
            end)
        else
            pcall(function()
                if game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    game.Players.LocalPlayer.Character.HumanoidRootPart.Anchored = false
                end
            end)
        end
        task.wait(0.01)
    end
end)

-- ระบบ Auto Attack & Skill
task.spawn(function()
    while task.wait(0.2) do
        if (_G.AutoFarm or _G.AutoDunFarm or _G.AutoFarmArea or _G.AutoChest) and _G.SelectedWeapon then
            pcall(function()
                local char = game.Players.LocalPlayer.Character
                local weapon = game.Players.LocalPlayer.Backpack:FindFirstChild(_G.SelectedWeapon) or char:FindFirstChild(_G.SelectedWeapon)
                if weapon then
                    if weapon.Parent ~= char then char.Humanoid:EquipTool(weapon) end
                    weapon:Activate()
                    
                    if _G.AutoSkill and #_G.SelectedSkills > 0 then
                        for _, skill in pairs(_G.SelectedSkills) do
                            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode[skill], false, game)
                            task.wait(0.01)
                            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode[skill], false, game)
                        end
                    end
                end
            end)
        end
    end
end)

