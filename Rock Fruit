-- ระบบ Auto Chest
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoChest then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local char = lp.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                
                local rewardGui = lp.PlayerGui:FindFirstChild("HUD") and lp.PlayerGui.HUD:FindFirstChild("Rewards")
                local chestCard = rewardGui and rewardGui:FindFirstChild("ChestCard")
                if chestCard and chestCard.Visible == true then
                    for i = 1, 5 do
                        local cardBtn = chestCard.Inset:FindFirstChild(tostring(i))
                        if cardBtn and cardBtn:FindFirstChild("Frame") and cardBtn.Frame:FindFirstChild("Button") then
                            local targetBtn = cardBtn.Frame.Button
                            firesignal(targetBtn.MouseButton1Click)
                            firesignal(targetBtn.Activated)
                        end
                    end
                end

                local chest = nil
                local minDist = math.huge
                for _, v in pairs(game.Workspace:GetDescendants()) do
                    if v.Name == "ChestRef" and v:IsA("BasePart") then
                        local dist = (hrp.Position - v.Position).Magnitude
                        if dist < minDist then minDist = dist; chest = v end
                    end
                end

                if chest and hrp then
                    local nearbyVillain = nil
                    if MobFolder then
                        for _, m in pairs(MobFolder:GetChildren()) do
                            if m.Name == "Villain" and m:FindFirstChild("Humanoid") and m.Humanoid.Health > 0 and m:FindFirstChild("HumanoidRootPart") then
                                if (m.HumanoidRootPart.Position - chest.Position).Magnitude < 45 then nearbyVillain = m; break end
                            end
                        end
                    end

                    if nearbyVillain then
                        hrp.CFrame = nearbyVillain.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                        local weapon = char:FindFirstChild(_G.SelectedWeapon) or lp.Backpack:FindFirstChild(_G.SelectedWeapon)
                        if weapon then 
                            if weapon.Parent ~= char then char.Humanoid:EquipTool(weapon) end
                            weapon:Activate() 
                        end
                    else
                        hrp.CFrame = chest.CFrame
                        local p = chest:FindFirstChildOfClass("ProximityPrompt") or chest:FindFirstChildWhichIsA("ProximityPrompt", true)
                        if p then
                            p.MaxActivationDistance = 9999
                            p.HoldDuration = 0
                            p.RequiresLineOfSight = false
                            p:InputHoldBegin(); task.wait(0.1); p:InputHoldEnd()
                        end
                    end
                end
            end)
        end
    end
end)

-- ระบบวาร์ปฟาร์ม
task.spawn(function()
    while task.wait() do
        if (_G.AutoFarm and _G.FarmType ~= "None") or (_G.AutoDunFarm and _G.DunFarmType ~= "None") or (_G.AutoFarmArea) then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local currentFolder = _G.AutoDunFarm and DunMobFolder or MobFolder
                local currentType = _G.AutoDunFarm and _G.DunFarmType or _G.FarmType
                local mainTarget = nil

                for _, v in pairs(currentFolder:GetChildren()) do
                    if (_G.AutoFarmArea or v.Name == currentType) and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                        if v.Humanoid.Health >= v.Humanoid.MaxHealth then
                            hrp.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 0, 1)
                            local weapon = lp.Character:FindFirstChild(_G.SelectedWeapon) or lp.Backpack:FindFirstChild(_G.SelectedWeapon)
                            if weapon then 
                                if weapon.Parent ~= lp.Character then lp.Character.Humanoid:EquipTool(weapon) end
                                weapon:Activate() 
                            end
                            task.wait(0.05)
                        end
                        if not mainTarget then mainTarget = v end
                    end
                end
                if mainTarget and mainTarget:FindFirstChild("HumanoidRootPart") then
                    local mobPos = mainTarget.HumanoidRootPart.Position
                    hrp.CFrame = CFrame.lookAt(mobPos + Vector3.new(0, _G.DistanceAbove, 0), mobPos)
                end
            end)
        end
    end
end)

