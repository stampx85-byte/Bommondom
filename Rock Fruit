-- ฟังก์ชันดึงข้อมูลล่าสุด (Updated for Real-time)
local function getMobList()
    local mobs = {}
    if MobFolder then
        for _, v in pairs(MobFolder:GetChildren()) do
            if v:IsA("Model") and not table.find(mobs, v.Name) then table.insert(mobs, v.Name) end
        end
    end
    return #mobs > 0 and mobs or {"No Mobs Found"}
end

local function getDunMobList()
    local mobs = {}
    if DunMobFolder then
        for _, v in pairs(DunMobFolder:GetChildren()) do
            if v:IsA("Model") and not table.find(mobs, v.Name) then table.insert(mobs, v.Name) end
        end
    end
    return #mobs > 0 and mobs or {"No DunMobs Found"}
end

local function getNPCList()
    local npcs = {}
    if NPCFolder then
        for _, v in pairs(NPCFolder:GetChildren()) do table.insert(npcs, v.Name) end
    end
    return #npcs > 0 and npcs or {"No NPC Found"}
end

local function getIslandList()
    local islands = {}
    if IslandFolder then
        for _, v in pairs(IslandFolder:GetChildren()) do table.insert(islands, v.Name) end
    end
    return #islands > 0 and islands or {"No Island Found"}
end

local function getInventory()
    local items = {}
    local lp = game.Players.LocalPlayer
    if lp and lp:FindFirstChild("Backpack") then
        for _, v in pairs(lp.Backpack:GetChildren()) do
            if v:IsA("Tool") then table.insert(items, v.Name) end
        end
    end
    if lp.Character then
        for _, v in pairs(lp.Character:GetChildren()) do
            if v:IsA("Tool") then table.insert(items, v.Name) end
        end
    end
    return #items > 0 and items or {"No Weapon Found"}
end

