-- Horror Mini Executor V3.0 [Expanded UI & Power Punch Edition]
local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")
local ScreenGui = Instance.new("ScreenGui")

-- [[ คงเดิม + เพิ่ม POWER PUNCH LOGIC ]] --
_G.GodSlap = false
_G.PowerPunchActive = false

local function getRemotes()
    local rems = {}
    if lp.Character then
        for _, tool in pairs(lp.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Remote") then
                table.insert(rems, tool.Remote)
            end
        end
    end
    return rems
end

-- ฟังก์ชันบังคับถือ Power Punch
local function equipPowerPunch()
    if _G.PowerPunchActive then
        local backpack = lp:FindFirstChild("Backpack")
        local char = lp.Character
        if char then
            local tool = backpack and backpack:FindFirstChild("Power Punch") or char:FindFirstChild("Power Punch")
            if tool and tool.Parent ~= char then
                tool.Parent = char
            end
        end
    end
end

task.spawn(function()
    while true do
        if _G.GodSlap or _G.PowerPunchActive then
            equipPowerPunch() -- บังคับถือถ้าเปิดใช้งาน
            local currentRemotes = getRemotes()
            if #currentRemotes > 0 then
                for _, target in pairs(Players:GetPlayers()) do
                    if target ~= lp and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                        local targetPos = target.Character.HumanoidRootPart.Position
                        for _, remote in pairs(currentRemotes) do
                            remote:FireServer("LeftDown", targetPos)
                            pcall(function()
                                local handle = remote.Parent:FindFirstChild("Handle")
                                if handle then
                                    handle.Size = Vector3.new(200, 200, 200)
                                    handle.CanCollide = false
                                    handle.Massless = true
                                    handle.CFrame = target.Character.HumanoidRootPart.CFrame
                                end
                            end)
                        end
                    end
                end
            end
        end
        RunService.Heartbeat:Wait()
    end
end)

-- [[ คงเดิม: LOGIC ต้านแอดมิน ]] --
_G.AntiAdmin = true
task.spawn(function()
    while true do
        if _G.AntiAdmin then
            pcall(function()
                local char = lp.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.Health = char.Humanoid.MaxHealth
                    char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
                end
            end)
        end
        task.wait(0.1)
    end
end)

