-- CORE ENGINE (FIXED RESPAWN LOGIC)
local lastWCount = 0
RS.RenderStepped:Connect(function()
    if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
        if _antiSit then char.Humanoid.Sit = false end
        if _antiRagdoll then char.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
        
        local tools = {}
        if Player.Backpack then for _, v in pairs(Player.Backpack:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end end
        for _, v in pairs(char:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end
        
        if #tools ~= lastWCount then
            lastWCount = #tools
            for _, c in pairs(WScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
            for _, t in pairs(tools) do
                local b = Instance.new("TextButton", WScroll)
                b.Size = UDim2.new(1, -10, 0, 30); b.Text = t.Name; b.BackgroundColor3 = Color3.fromRGB(60, 0, 0); b.TextColor3 = Color3.fromRGB(255, 255, 255); b.Font = Enum.Font.SpecialElite; Instance.new("UICorner", b)
                b.MouseButton1Click:Connect(function() _selectedWeapon = t.Name end)
            end
        end

        if (_killEnabled or _rpgMode) and _selectedWeapon then
            local tool = char:FindFirstChild(_selectedWeapon) or (Player.Backpack and Player.Backpack:FindFirstChild(_selectedWeapon))
            local target = nil; local dist = 1000
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= Player and v.Team ~= Player.Team and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.Humanoid.Health > 0 then
                    local d = (char.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
                    if d < dist then target = v.Character; dist = d end
                end
            end
            if tool and target then
                if tool.Parent ~= char then char.Humanoid:EquipTool(tool) end
                local offset = _rpgMode and CFrame.new(math.random(-5,5), 20, math.random(-5,5)) or CFrame.new(0, 0, 2.2)
                char.HumanoidRootPart.CFrame = CFrame.new((target.HumanoidRootPart.CFrame * offset).Position, target.HumanoidRootPart.Position)
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.HumanoidRootPart.Position)
                tool:Activate()
                task.spawn(function()
                    VIM:SendMouseButtonEvent(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2, 0, true, game, 0)
                    task.wait(0.01)
                    VIM:SendMouseButtonEvent(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2, 0, false, game, 0)
                end)
            end
        end
    end
end)

