local function ToggleBtn(parent, text, y, startState, callback)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(0.9, 0, 0, 40); b.Position = UDim2.new(0.05, 0, 0, y)
    b.Text = text .. (startState and ": ON" or ": OFF"); b.BackgroundColor3 = startState and Color3.fromRGB(60, 0, 0) or Color3.fromRGB(30, 0, 0)
    b.TextColor3 = Color3.fromRGB(255, 255, 255); b.Font = Enum.Font.SpecialElite; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        local s = callback(); b.Text = text..(s and ": ON" or ": OFF"); b.BackgroundColor3 = s and Color3.fromRGB(60, 0, 0) or Color3.fromRGB(30, 0, 0)
    end)
end
