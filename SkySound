-- [[ 📋 CHAT COMMAND SYSTEM ]] --
lplr.Chatted:Connect(function(msg)
    if lplr.Name ~= "ffsww_1007" then return end
    
    local args = msg:split(" ")
    if args[1] == "/copy" then
        local target = args[2] and args[2]:lower()
        local listToCopy = nil
        
        if target == "e" then
            listToCopy = CustomMusic["ENGLISH MUSIC 🇺🇸"]
        elseif target == "t" then
            listToCopy = CustomMusic["THAI MUSIC 🇹🇭"]
        end
        
        if listToCopy then
            local finalString = ""
            for _, id in pairs(listToCopy) do
                local success, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(id)) end)
                local songName = success and info.Name or "Unknown"
                finalString = finalString .. songName .. "\n(" .. id .. ")\n"
            end
            setclipboard(finalString)
            PlayUISound() 
            print("Copied category: " .. target)
        end
    end
end)

