-- [[ ฟังก์ชันการทำงานเดิม ]] --
local function smartInteract(obj)
    local root = getRoot()
    if not obj or not root then return end
    root.CFrame = obj:GetPivot()
    task.wait(0.1)
    local tool = Player.Backpack:FindFirstChildOfClass("Tool")
    if tool then Player.Character.Humanoid:EquipTool(tool) end
    local p = obj:FindFirstChildOfClass("ProximityPrompt") or obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if p then
        p.MaxActivationDistance = math.huge; p.HoldDuration = 0
        p:InputHoldBegin(); task.wait(0.1); p:InputHoldEnd()
    end
end

local function getPriorityBall()
    local target = nil; local maxVal = -1
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v.Name:find("Ball") and (v:FindFirstChildOfClass("ProximityPrompt") or v:FindFirstChildWhichIsA("ProximityPrompt", true)) then
            local value = tonumber(v.Name:match("%d+")) or 0
            if value > maxVal then maxVal = value; target = v end
        end
    end
    if not target then
        for _, v in pairs(game.Workspace:GetDescendants()) do
            if v.Name:find("Ball") and v:FindFirstChildOfClass("ProximityPrompt") then return v end
        end
    end
    return target
end

-- [[ Loop ระบบ Auto ]] --
task.spawn(function()
    while task.wait(0.1) do
        if getgenv().KaronsonEnabled then
            local ball = getPriorityBall()
            if ball then smartInteract(ball) end
        end
        if getgenv().AutoSellEnabled then
            local recap = game.Workspace:FindFirstChild("Recuperateur", true)
            if recap then smartInteract(recap) end
        end
    end
end)

