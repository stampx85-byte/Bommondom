-- === [ ระบบ Catalog Service พร้อมตัวเช็คซ้ำ ] ===
local function TryOn(id)
    local character = player.Character
    if not character then return end
    
    local alreadyWearing = false
    for _, v in ipairs(character:GetDescendants()) do
        if v:IsA("Accessory") or v:IsA("Tool") then
            if v:FindFirstChild("AssetId") and v.AssetId.Value == id then
                alreadyWearing = true
                break
            end
        end
    end

    if not alreadyWearing then
        pcall(function()
            ReplicatedStorage.Catalog.TryOn:InvokeServer({["Id"] = id})
        end)
    end
end

local function Unwear(id)
    pcall(function()
        ReplicatedStorage.Catalog.Unwear:InvokeServer({["Id"] = id})
    end)
end

