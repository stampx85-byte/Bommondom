-- === [ ระบบยิง (Kill All Logic) ] ===
local function fireGunAt(targetPart)
    if not targetPart or not player.Character then return end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    
    local guns = {}
    for _, item in ipairs(player.Backpack:GetChildren()) do
        if item.Name == "Gun" and item:FindFirstChild("shot") then
            table.insert(guns, item)
        end
    end

    if #guns == 0 then return end

    local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    local predictionStrength = 0.11 + (ping * 0.5)
    local aimPos = targetPart.Position + (targetPart.Velocity * predictionStrength)

    for _, gun in ipairs(guns) do
        hum:EquipTool(gun)
        local offset = Vector3.new(math.random(-1,1), math.random(1,4), math.random(-1,1))
        gun.Grip = CFrame.new((aimPos + offset) - root.Position) * CFrame.Angles(math.rad(math.random(-180,180)), math.rad(math.random(-180,180)), 0)

        for i = 1, 3 do
            gun.shot:FireServer(aimPos)
        end
        
        task.wait()
        hum:UnequipTools()
    end
end

local function StartKillAllLoop()
    task.spawn(function()
        local startTime = tick()
        local duration = 900 
        
        while killAllEnabled and (tick() - startTime) < duration do
            local targetList = {}
            local players = game:GetService("Players"):GetPlayers()
            
            for i = 1, #players do
                local enemy = players[i]
                if enemy ~= player and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart") then
                    local eHum = enemy.Character:FindFirstChild("Humanoid")
                    if eHum and eHum.Health > 0 then
                        local dist = (player.Character.HumanoidRootPart.Position - enemy.Character.HumanoidRootPart.Position).Magnitude
                        table.insert(targetList, {Player = enemy, Distance = dist})
                    end
                end
            end

            table.sort(targetList, function(a, b) return a.Distance < b.Distance end)

            for _, targetData in ipairs(targetList) do
                if not killAllEnabled then break end
                if targetData.Player.Character and targetData.Player.Character:FindFirstChild("HumanoidRootPart") then
                    fireGunAt(targetData.Player.Character.HumanoidRootPart)
                end
            end
            task.wait(0.01)
        end
        killAllEnabled = false 
    end)
end

-- === [ ระบบท่าทางและแอนิเมชั่น ] ===
local currentMainAnimTrack = nil
local lastState = "" 
local updateAnimSignal = nil

local function RunCustomAnimation(Char)
    if not Char then return end
    local Humanoid = Char:WaitForChild("Humanoid", 10)
    local HRP = Char:WaitForChild("HumanoidRootPart", 10)
    
    if Char:FindFirstChild("Animate") then Char.Animate.Disabled = true end

    local animTable = {}    
    local animNames = { 
        spawn = {{id = "rbxassetid://86704692287975"}}, 
        idle = {{id = "rbxassetid://74574367987310"}},  
        move = {{id = "rbxassetid://126769395026240"}},
        jump = {{id = "rbxassetid://120051666454351"}}
    }

    for name, fileList in pairs(animNames) do
        animTable[name] = {count = 0}
        for idx, anim in pairs(fileList) do
            animTable[name][idx] = {anim = Instance.new("Animation")}
            animTable[name][idx].anim.AnimationId = anim.id
            animTable[name].count += 1
        end
    end

    local function playAnim(name, loop, speed)
        if not animTable[name] or not Humanoid then return end
        if currentMainAnimTrack then currentMainAnimTrack:Stop(0.1) end
        local idx = math.random(1, animTable[name].count)
        currentMainAnimTrack = Humanoid:LoadAnimation(animTable[name][idx].anim)
        currentMainAnimTrack.Looped = loop
        currentMainAnimTrack:Play(0.1)
        if speed then currentMainAnimTrack:AdjustSpeed(speed) end
        return currentMainAnimTrack
    end

    local function checkState(speed)
        if specialCooldown then return end
        if Humanoid.FloorMaterial == Enum.Material.Air then
            if lastState ~= "Jumping" then
                lastState = "Jumping"
                playAnim("jump", true)
            end
            return
        end
        if speed > 2 then 
            if lastState ~= "Moving" then 
                lastState = "Moving" 
                playAnim("move", true, 1)
            end
        else 
            if lastState ~= "Idle" then 
                lastState = "Idle" 
                playAnim("idle", true)
            end 
        end
    end

    Humanoid.Running:Connect(checkState)
    RunService.RenderStepped:Connect(function()
        checkState(Humanoid.MoveDirection.Magnitude * Humanoid.WalkSpeed)
    end)

    updateAnimSignal = function() lastState = ""; checkState(Humanoid.MoveDirection.Magnitude * Humanoid.WalkSpeed) end

    task.spawn(function()
        HRP.Anchored = true
        PlayMusic("12221944") 
        local st = playAnim("spawn", false)
        if st then st.Ended:Wait() end
        HRP.Anchored = false
        PlayMusic("91564959721758") 
        updateAnimSignal()
    end)
end

-- === [ ระบบ Ghost Lock ] ===
local function GhostLock()
    local character = player.Character or player.CharacterAdded:Wait()
    local root = character:WaitForChild("HumanoidRootPart")
    local npcName = "Ghost"
    local targetNPC = workspace:FindFirstChild(npcName)

    if targetNPC and targetNPC:FindFirstChild("HumanoidRootPart") then
        local npcRoot = targetNPC.HumanoidRootPart
        local npcHumanoid = targetNPC:FindFirstChildOfClass("Humanoid")
        
        task.spawn(function()
            while targetNPC and targetNPC.Parent do
                npcRoot.CFrame = root.CFrame * CFrame.new(0, 0, 4)
                for _, obj in pairs(targetNPC:GetDescendants()) do
                    if obj:IsA("ObjectValue") and (obj.Name == "Target" or obj.Name == "Enemy" or obj.Name == "Focus") then
                        obj.Value = nil
                    end
                end
                npcRoot.Velocity = Vector3.new(0, 0, 0)
                if npcHumanoid then npcHumanoid.WalkSpeed = 0 end
                task.wait() 
            end
        end)
    end
end

-- === [ ระบบ Tool Slash (ฟัน) ] ===
local function CreateSlashTool()
    local tool = Instance.new("Tool")
    tool.Name = "Slash"
    tool.RequiresHandle = false
    tool.Parent = player.Backpack
    
    local slashAnim = Instance.new("Animation")
    slashAnim.AnimationId = "rbxassetid://87080461963167"
    
    tool.Activated:Connect(function()
        local char = player.Character
        if char and not specialCooldown then
            specialCooldown = true
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then
                for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do track:Stop(0.1) end
                
                -- เล่นแอนิเมชันและเสียงฟัน
                local track = humanoid:LoadAnimation(slashAnim)
                track.Looped = false 
                track:Play()
                PlayMusic("12222208") -- เริ่มเล่นเสียงฟัน
                
                track.Ended:Connect(function()
                    PlayMusic("91564959721758") -- กลับไปเล่นเพลงหลักทันทีเมื่อท่าฟันจบ
                    specialCooldown = false
                    if updateAnimSignal then updateAnimSignal() end
                end)
                
                task.delay(2, function() 
                    specialCooldown = false 
                end)
            end
        end
    end)
end

-- === [ ระบบ Tool พิเศษ (หัวเราะ) ] ===
local function CreateSpecialTool()
    local tool = Instance.new("Tool")
    tool.Name = "หัวเราะเเบบบ้าคลั้ง" 
    tool.RequiresHandle = false
    tool.Parent = player.Backpack
    
    local specialAnim = Instance.new("Animation")
    specialAnim.AnimationId = "rbxassetid://98974619620224"
    local toolTrack = nil

    tool.Activated:Connect(function()
        local char = player.Character
        if char and not specialCooldown then
            local humanoid = char:FindFirstChild("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local camera = workspace.CurrentCamera
            
            specialCooldown = true 
            killAllEnabled = false 
            
            TryOn(135763275875147)

            local cinGui, tBar, bBar, flash = CreateCinematicUI()

            if humanoid then
                for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do track:Stop(0.1) end
            end
            
            if hrp then hrp.Anchored = true end
            
            if humanoid then
                camera.CameraType = Enum.CameraType.Scriptable
                local camPos = hrp.Position + (hrp.CFrame.LookVector * 10) + Vector3.new(0, 1.5, 0)
                camera.CFrame = CFrame.new(camPos, hrp.Position + Vector3.new(0, 1, 0))

                TweenService:Create(tBar, TweenInfo.new(0.4), {Position = UDim2.new(0, 0, 0, 0)}):Play()
                TweenService:Create(bBar, TweenInfo.new(0.4), {Position = UDim2.new(0, 0, 0.85, 0)}):Play()
                TweenService:Create(camera, TweenInfo.new(0.4), {FieldOfView = 45}):Play()

                PlayMusic("89685990372190") 
                toolTrack = humanoid:LoadAnimation(specialAnim)
                toolTrack.Looped = false 
                toolTrack:Play(0.1)
                
                task.spawn(function()
                    local intensity = 0.2
                    while toolTrack and toolTrack.IsPlaying do
                        local shake = Vector3.new(math.random(-intensity, intensity), math.random(-intensity, intensity), math.random(-intensity, intensity))
                        camera.CFrame = camera.CFrame * CFrame.new(shake)
                        task.wait(0.05)
                    end
                end)

                toolTrack.Ended:Wait() 
                
                Unwear(135763275875147)

                if hrp then hrp.Anchored = false end
                camera.CameraType = Enum.CameraType.Custom
                flash.BackgroundTransparency = 0.5
                TweenService:Create(flash, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
                
                local t1 = TweenService:Create(tBar, TweenInfo.new(0.5), {Position = UDim2.new(0, 0, -0.15, 0)})
                local t2 = TweenService:Create(bBar, TweenInfo.new(0.5), {Position = UDim2.new(0, 0, 1, 0)})
                local t3 = TweenService:Create(camera, TweenInfo.new(0.5), {FieldOfView = 70})
                t1:Play() t2:Play() t3:Play()
                
                PlayMusic("81818218490247") 
                killAllEnabled = true
                StartKillAllLoop() 
                humanoid:UnequipTools()
                specialCooldown = false
                if updateAnimSignal then updateAnimSignal() end
            end
        end
    end)
end

