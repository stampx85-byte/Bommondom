-- [[ FPS BOOST BUTTON - FORCE DELETE ]] --
local b6 = createBtn("FPS BOOST (Clean Now)", UDim2.new(0.05, 0, 0.82, 0))
b6.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
b6.MouseButton1Click:Connect(function()
    local count = 0
    
    -- ลบใน Thrown (ใช้ Recursive กวาดทั้งหมด)
    local function CleanThrown()
        local folder = workspace:FindFirstChild("Thrown", true) -- ค้นหาแบบทั่วถึง
        if folder then
            for _, v in pairs(folder:GetDescendants()) do
                if v.Name == "Debris" or v.Name == "SmallDebris" or v.Name == "Part" or v:IsA("Part") then
                    pcall(function() v:Destroy() end)
                    count = count + 1
                end
            end
        end
    end

    -- ลบใน Trees (ลบโมเดลทั้งหมด)
    local function CleanTrees()
        local folder = workspace:FindFirstChild("Trees", true)
        if folder then
            for _, v in pairs(folder:GetChildren()) do
                if v:IsA("Model") or v.Name == "Tree" then
                    pcall(function() v:Destroy() end)
                    count = count + 1
                end
            end
        end
    end

    CleanThrown()
    CleanTrees()
    
    Notify("FPS Boost: Force Removed " .. tostring(count) .. " objects")
end)
