RunService.RenderStepped:Connect(function()
    if AIMBOT_ENABLED and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        local target = findGlobalTarget()
        if target then
            local RootPart = Player.Character.HumanoidRootPart
            RootPart.CFrame = CFrame.lookAt(RootPart.Position, Vector3.new(target.Position.X, RootPart.Position.Y, target.Position.Z))
        end
    end
end)

