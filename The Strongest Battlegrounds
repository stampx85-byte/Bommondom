-- [Target System]
local function findGlobalTarget()
    local Character = Player.Character
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return nil end
    local RootPart = Character.HumanoidRootPart
    local closest, lastDist = nil, 80 
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Parent ~= Character then
            local isPlayer = game.Players:GetPlayerFromCharacter(obj.Parent)
            local isDummy = not isPlayer
            local canTarget = (TARGET_MODE == 1) or (TARGET_MODE == 2 and isPlayer) or (TARGET_MODE == 3 and isDummy)
            if canTarget then
                local targetRoot = obj.Parent:FindFirstChild("HumanoidRootPart")
                if targetRoot then
                    local dist = (RootPart.Position - targetRoot.Position).Magnitude
                    if dist < lastDist then lastDist = dist closest = targetRoot end
                end
            end
        end
    end
    return closest
end

-- [Main Logic for Respawn]
local function ConnectCharacter(Character)
    local Humanoid = Character:WaitForChild("Humanoid")
    local RootPart = Character:WaitForChild("HumanoidRootPart")

    Humanoid.AnimationPlayed:Connect(function(track)
        local animId = track.Animation.AnimationId
        if (animId:find(TARGET_ANIM_ID) or animId:find(Q_DASH_ID)) then
            local target = findGlobalTarget()
            task.wait(track.Length * 0.40)
            if target and target.Parent then
                if TECH_SUB_ENABLED then
                    task.spawn(function() VirtualInput:SendKeyEvent(true, DASH_KEY, false, game) end)
                    local startTime = tick()
                    local connection
                    connection = RunService.Heartbeat:Connect(function()
                        local elapsed = tick() - startTime
                        if target and target.Parent and elapsed < LOCK_DURATION then
                            local tPos = target.Position
                            if elapsed < 0.4 then
                                local sideOffset = math.sin(elapsed * 40) * 7 
                                RootPart.CFrame = CFrame.new(tPos + (target.CFrame.RightVector * sideOffset), tPos)
                            else
                                local camLook = Camera.CFrame.LookVector
                                local warpPos = (camLook.Y < -0.3) and target.Position + (target.CFrame.LookVector * -2.5) or target.Position + (target.CFrame.LookVector * 1.5)
                                RootPart.CFrame = CFrame.new(warpPos, Vector3.new(tPos.X, tPos.Y + 60, tPos.Z))
                            end
                        else
                            VirtualInput:SendKeyEvent(false, DASH_KEY, false, game)
                            connection:Disconnect()
                        end
                    end)
                elseif NORMAL_ENABLED then
                    task.spawn(function() VirtualInput:SendKeyEvent(true, DASH_KEY, false, game) end)
                    local startTime = tick()
                    local connection
                    connection = RunService.Heartbeat:Connect(function()
                        if target and target.Parent and (tick() - startTime) < LOCK_DURATION then
                            RootPart.CFrame = CFrame.new(target.Position + (target.CFrame.LookVector * 1.2), Vector3.new(target.Position.X, target.Position.Y + 15, target.Position.Z))
                        else
                            VirtualInput:SendKeyEvent(false, DASH_KEY, false, game)
                            connection:Disconnect()
                        end
                    end)
                end
            end
        elseif (SPIN_ANIM_IDS[animId:sub(-11)] or SPIN_ANIM_IDS[animId]) and SPIN_ENABLED then
            if tick() - LAST_SPIN < SPIN_DELAY then return end
            LAST_SPIN = tick()
            local target = findGlobalTarget()
            if target and target.Parent then
                VirtualInput:SendKeyEvent(true, Enum.KeyCode.A, false, game) 
                task.spawn(function() VirtualInput:SendKeyEvent(true, DASH_KEY, false, game) end)
                local startTime, angle = tick(), 0
                local connection
                connection = RunService.Heartbeat:Connect(function()
                    if target and target.Parent and (tick() - startTime) < LOCK_DURATION then
                        angle = angle + 0.8
                        local offset = Vector3.new(math.cos(angle) * 6, 0, math.sin(angle) * 6)
                        RootPart.CFrame = CFrame.new(target.Position + offset, target.Position)
                    else
                        VirtualInput:SendKeyEvent(false, DASH_KEY, false, game)
                        VirtualInput:SendKeyEvent(false, Enum.KeyCode.A, false, game)
                        connection:Disconnect()
                    end
                end)
            end
        end
    end)
end

if Player.Character then ConnectCharacter(Player.Character) end
