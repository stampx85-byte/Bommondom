-- ฟังก์ชันสร้างปุ่มรันสคริปต์
local function CreateCarButton(name, loadstring_code)
    local Btn = Instance.new("TextButton")
    Btn.Parent = ScrollingFrame
    Btn.Size = UDim2.new(1, 0, 0, 35)
    Btn.BackgroundColor3 = Color3.fromRGB(60, 0, 0)
    Btn.Text = "RUN: " .. name
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.Font = Enum.Font.SpecialElite
    Btn.TextSize = 14
    Instance.new("UICorner", Btn)

    local confirmMode = false
    Btn.MouseButton1Click:Connect(function()
        if not confirmMode then
            confirmMode = true
            Btn.Text = "CONFIRM?"
            Btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
            task.wait(2)
            confirmMode = false
            Btn.Text = "RUN: " .. name
            Btn.BackgroundColor3 = Color3.fromRGB(60, 0, 0)
        else
            Btn.Text = "EXECUTING..."
            loadstring(game:HttpGet(loadstring_code))()
            task.wait(0.5)
            Btn.Text = "RUN: " .. name
            Btn.BackgroundColor3 = Color3.fromRGB(60, 0, 0)
            confirmMode = false
        end
    end)
end

