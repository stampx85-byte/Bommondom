local function decStrToHex(s)
    local chars = "0123456789ABCDEF"; local hexResult = ""; local numStr = s
    while numStr ~= "0" and numStr ~= "" do
        local remainder = 0; local newS = ""
        for i = 1, #numStr do
            local d = tonumber(string.sub(numStr, i, i))
            remainder = remainder * 10 + d
            if newS ~= "" or remainder >= 16 then newS = newS .. tostring(math.floor(remainder / 16)) remainder = remainder % 16 end
        end
        hexResult = string.sub(chars, remainder + 1, remainder + 1) .. hexResult
        numStr = (newS ~= "" and newS or "0")
    end
    return hexResult ~= "" and hexResult or "0"
end

