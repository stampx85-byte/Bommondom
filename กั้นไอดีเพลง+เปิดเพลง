        -- เข้ารหัส ID ตามฟังก์ชันของคุณ
        local encodedID = encodeID(rawID)
        
        -- ค้นหา Remote ตามโครงสร้างใหม่ที่คุณให้มา
        local re = game:GetService("ReplicatedStorage"):FindFirstChild("RE")
        if re and re:FindFirstChild("PlayerToolEvent") then
            -- ส่งข้อมูลไปยัง Server: FireServer("ToolMusicText", "ID ที่เข้ารหัส", true)
            re.PlayerToolEvent:FireServer("ToolMusicText", encodedID, true)
            
            -- แสดงสถานะชั่วคราว
            PlayButton.Text = "ส่งข้อมูลสำเร็จ!"
