-- [[ HOOKMETAMETHOD: THE FIX ]]
local namecall
namecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod():lower()
    
    if not checkcaller() and method == "fireserver" then
        if tostring(self) == "PlayerToolEvent" or args[1] == "ToolMusicText" then
            local realId = args[2] -- เก็บ ID จริงไว้
            
            -- 1. บังคับส่ง ID จริงไปที่ Server แบบเงียบๆ (ไม่ผ่าน Hook ตัวนี้ซ้ำ)
            task.spawn(function()
                -- ใช้ 'namecall' เดิมส่งค่าจริง เพื่อให้เพลงเล่น
                namecall(self, "ToolMusicText", realId, true)
            end)
            
            -- 2. แก้ไข 'args' ที่กำลังจะส่งออกไปตามปกติ ให้เป็นค่าปลอม
            -- วิธีนี้ Logger จะจับได้แค่ตัวแปรที่ถูกแก้แล้ว (ค่าปลอม)
            args[2] = getgenv().replacement or "nil"
            return namecall(self, unpack(args))
        end
    end
    return namecall(self, ...)
end)

-- [[ EVENT: PLAY ]]
SendBtn.MouseButton1Click:Connect(function()
    local inputId = IdInput.Text
    if inputId ~= "" then
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("PlayerToolEvent")
        if remote then
            -- ส่งไปหา Hook ด้านบน
            remote:FireServer("ToolMusicText", inputId) 
            Status.Text = "SENT (HIDDEN)"
            task.wait(1)
            Status.Text = "READY"
        end
    end
end)
