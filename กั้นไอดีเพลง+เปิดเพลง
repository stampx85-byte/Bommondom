-- [[ HOOKMETAMETHOD: AUTOMATIC BYPASS ]]
local namecall
namecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod():lower()
    
    -- ดักจับการส่ง Remote เพลงทุกลูกที่ผ่านเครื่องเรา
    if not checkcaller() and method == "fireserver" then
        if tostring(self) == "PlayerToolEvent" or args[1] == "ToolMusicText" then
            local originalId = tostring(args[2])
            local encodedId = toASCII(originalId)
            
            -- แอบส่ง ID จริงที่แปลงเป็น ASCII แล้วไปที่เซิร์ฟเวอร์
            task.spawn(function()
                namecall(self, "ToolMusicText", encodedId, true)
            end)
            
            -- หลอก Logger ให้เห็นเป็นค่าปลอมที่เราตั้งไว้
            args[2] = getgenv().replacement or "nil"
            return namecall(self, unpack(args))
        end
    end
    return namecall(self, ...)
end)

-- [[ EVENT: PLAY BUTTON ]]
SendBtn.MouseButton1Click:Connect(function()
    local inputId = IdInput.Text
    if inputId ~= "" then
        -- ค้นหา Remote ของเกม (PlayerToolEvent)
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("PlayerToolEvent")
        if remote then
            -- สั่ง FireServer ปกติ แต่จะโดน Hook ด้านบนแปลงเป็น ASCII ให้อัตโนมัติ
            remote:FireServer("ToolMusicText", inputId) 
            Status.Text = "ENCRYPTED & SENT"
            task.wait(1.5)
            Status.Text = "SYSTEM ACTIVE"
        else
            Status.Text = "REMOTE ERROR"
        end
    end
end)

