        -- 2. ค้นหา Remote และส่งค่าที่แปลงแล้วออกไป
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild(REMOTE_NAME)
        if remote then
            -- ส่งข้อมูลไปยัง Remote (กั้น ID ด้วยการใช้ ASCII)
            remote:FireServer("ToolMusicText", encodedId) 
            
            Status.Text = "SENT: " .. encodedId
            print("ffsww_1007 | Encoded ID Sent: " .. encodedId)
            
            task.wait(2)
            Status.Text = "READY TO ENCODE"
        else
            Status.Text = "REMOTE NOT FOUND"
        end
    end
end)
