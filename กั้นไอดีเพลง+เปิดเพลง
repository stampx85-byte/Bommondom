local function GetAudioInfo(id)
    local success, info = pcall(function() return MarketService:GetProductInfo(id) end)
    return success and info or nil
end

local function CreateAudioCard(ownerName, id)
    if ScrollAudios:FindFirstChild(id) then return end
    local Card = Instance.new("Frame", ScrollAudios)
    Card.Name = id; Card.Size = UDim2.new(1, -5, 0, 65); Card.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    Instance.new("UICorner", Card); Instance.new("UIStroke", Card).Color = Color3.fromRGB(30, 30, 35)
    
    local AudioImg = Instance.new("ImageLabel", Card)
    AudioImg.Size = UDim2.new(0, 45, 0, 45); AudioImg.Position = UDim2.new(0, 8, 0.5, -22.5)
    AudioImg.Image = "https://www.roblox.com/asset-thumbnail/image?assetId="..id.."&width=420&height=420&format=png"
    Instance.new("UICorner", AudioImg)

    local Info = Instance.new("TextLabel", Card)
    Info.Size = UDim2.new(1, -120, 1, 0); Info.Position = UDim2.new(0, 60, 0, 0)
    Info.BackgroundTransparency = 1; Info.TextColor3 = Color3.new(1,1,1); Info.TextXAlignment = Enum.TextXAlignment.Left; Info.RichText = true
    SetMinecraftFont(Info, 10)
    local musicData = GetAudioInfo(id)
    Info.Text = string.format("<font color='#ff2828'>%s</font>\nID: %s\nBY: %s", (musicData and musicData.Name or "Unknown"):sub(1,15), id, ownerName)
    
    local Copy = Instance.new("TextButton", Card)
    Copy.Size = UDim2.new(0, 50, 0, 25); Copy.Position = UDim2.new(1, -55, 0.5, -12.5)
    Copy.BackgroundColor3 = Color3.fromRGB(255, 30, 30); Copy.Text = "COPY"; Copy.TextColor3 = Color3.new(1,1,1)
    SetMinecraftFont(Copy, 11); Instance.new("UICorner", Copy)
    Copy.MouseButton1Click:Connect(function() setclipboard(tostring(id)); Copy.Text = "OK"; task.wait(0.5); Copy.Text = "COPY" end)
    ScrollAudios.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 5)
end

task.spawn(function()
    while true do
        for _, v in pairs(game:GetDescendants()) do
            if v:IsA("Sound") then
                if not v:GetAttribute("IsSkySound") then v.Volume = 0 end
                if v.SoundId ~= "" and v.TimeLength > 5 then
                    local cleanID = v.SoundId:match("%d+")
                    if cleanID then 
                        local owner = "Unknown"
                        local p = v.Parent
                        while p do
                            if p:IsA("Model") and game.Players:GetPlayerFromCharacter(p) then owner = game.Players:GetPlayerFromCharacter(p).Name break
                            elseif p:IsA("BackpackItem") and p.Parent and p.Parent:IsA("Backpack") then owner = p.Parent.Parent.Name break end
                            p = p.Parent
                        end
                        CreateAudioCard(owner, cleanID) 
                    end
                end
            end
        end
        task.wait(3)
    end
end)

