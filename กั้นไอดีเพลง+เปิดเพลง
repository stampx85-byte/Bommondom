-- [[ FUNCTION: TO ASCII (%NUMBER) ]]
local function encodeToASCII(str)
    local result = ""
    for i = 1, #str do
        local char = string.sub(str, i, i)
        -- แปลงเป็น % ตามด้วยเลข ASCII Code
        result = result .. "%" .. string.byte(char)
    end
    return result
end

