Title.TextSize = 16
Title.BackgroundTransparency = 1

--- [[ ระบบลาก UI (Mobile & PC Friendly) ]] ---
local dragToggle, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragToggle = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragToggle = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggle then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

--- [[ ฟังก์ชันเสริม ]] ---

local function createESP(target, name, color)
    if not target then return end
    if target:FindFirstChild("ItemESP") then target.ItemESP:Destroy() end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ItemESP"
    highlight.Parent = target
    highlight.FillColor = color
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ItemLabel"
    billboard.Parent = target
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 100, 0, 50)
    billboard.ExtentsOffset = Vector3.new(0, 3, 0)
    
    local label = Instance.new("TextLabel")
    label.Parent = billboard
    label.Size = UDim2.new(1, 0, 0.5, 0)
    label.Text = name
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
end

--- [[ ปุ่มควบคุม ]] ---

local function createButton(name, pos, color)
    local btn = Instance.new("TextButton")
    btn.Parent = MainFrame
    btn.Size = UDim2.new(0.85, 0, 0, 50)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SpecialElite
    btn.TextSize = 14
    Instance.new("UICorner", btn)
    return btn
end

local SwapBtn = createButton("GOD SWAP: OFF", UDim2.new(0.075, 0, 0.18, 0), Color3.fromRGB(60, 0, 0))
local LightBtn = createButton("AUTO LIGHT: OFF", UDim2.new(0.075, 0, 0.42, 0), Color3.fromRGB(40, 40, 40))
local TrackBtn = createButton("VIEW LOCATIONS", UDim2.new(0.075, 0, 0.72, 0), Color3.fromRGB(0, 40, 60))

--- [[ ระบบการทำงาน (Logics) ]] ---

TrackBtn.MouseButton1Click:Connect(function()
    tracking = not tracking
    TrackBtn.Text = tracking and "HIDE LOCATIONS" or "VIEW LOCATIONS"
    TrackBtn.BackgroundColor3 = tracking and Color3.fromRGB(0, 100, 150) or Color3.fromRGB(0, 40, 60)
    
    local items = {
        {Path = workspace:FindFirstChild("PickItem") and workspace.PickItem:FindFirstChild("Helmet"), Name = "Helmet", Color = Color3.fromRGB(255, 0, 0)},
        {Path = workspace:FindFirstChild("PickItem") and workspace.PickItem:FindFirstChild("Flash Light"), Name = "Flash Light", Color = Color3.fromRGB(255, 255, 0)}
    }
    
    for _, info in pairs(items) do
        if tracking and info.Path then
            createESP(info.Path, info.Name, info.Color)
        elseif info.Path then
            if info.Path:FindFirstChild("ItemESP") then info.Path.ItemESP:Destroy() end
            if info.Path:FindFirstChild("ItemLabel") then info.Path.ItemLabel:Destroy() end
        end
    end
end)

SwapBtn.MouseButton1Click:Connect(function()
    swapRunning = not swapRunning
    SwapBtn.Text = swapRunning and "GOD SWAP: ON" or "GOD SWAP: OFF"
    SwapBtn.BackgroundColor3 = swapRunning and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(60, 0, 0)
    
    if swapRunning then
        task.spawn(function()
            while swapRunning do
                local char = player.Character
                local bp = player.Backpack
                if char and bp then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    local t1 = bp:FindFirstChild(item1Name) or char:FindFirstChild(item1Name)
                    local t2 = bp:FindFirstChild(item2Name) or char:FindFirstChild(item2Name)
                    if t1 and t2 and hum then
                        hum:EquipTool(t1)
                        hum:EquipTool(t2)
                    end
                end
                RunService.Heartbeat:Wait()
            end
        end)
    end
end)

LightBtn.MouseButton1Click:Connect(function()
    lightRunning = not lightRunning
    LightBtn.Text = lightRunning and "AUTO LIGHT: ON" or "AUTO LIGHT: OFF"
    LightBtn.BackgroundColor3 = lightRunning and Color3.fromRGB(255, 100, 0) or Color3.fromRGB(40, 40, 40)
    
    if lightRunning then
        task.spawn(function()
            while lightRunning do
                local char = player.Character
                local tool = (char and char:FindFirstChild(item1Name)) or (player.Backpack:FindFirstChild(item1Name))
                if tool and tool:IsA("Tool") then
                    tool:Activate()
                end
                task.wait(0.1)
            end
        end)
    end
end)
