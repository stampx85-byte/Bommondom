--// --- [ METATABLE SYSTEM - PC UPGRADED ] --- //--
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
local set_readonly = setreadonly or make_readonly
local set_writeable = setwriteable or make_writeable

if set_writeable then set_writeable(mt, false) end
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if method == "Kick" or method == "kick" then return nil end
    if method == "FireServer" and self.Name == "MainEvent" then
        if args[1] == "TeleportDetect" or args[1] == "WalkSpeed" then return nil end
    end
    return oldNamecall(self, unpack(args))
end)
if set_readonly then set_readonly(mt, true) end

--// --- [ SYSTEM FUNCTIONS ] --- //--
local function applyAntiCrash(p)
    if not _G.antiCrashEnabled then return end
    local plrgui = p:WaitForChild("PlayerGui")
    local function cleanGui(gui)
        if _G.antiCrashEnabled and gui.Name == "Announcement" then gui:Destroy() end
    end
    for _, g in ipairs(plrgui:GetChildren()) do cleanGui(g) end
    plrgui.ChildAdded:Connect(cleanGui)
end

local function stashAllGuns()
    for _, item in ipairs(plr.Backpack:GetChildren()) do
        if item.Name == "Gun" then task.wait(0.05); toolStorage:FireServer("Save", "Gun") end
    end
    if plr.Character then
        for _, item in ipairs(plr.Character:GetChildren()) do
            if item.Name == "Gun" then item.Parent = plr.Backpack; task.wait(0.05); toolStorage:FireServer("Save", "Gun") end
        end
    end
end

local function pullAllGuns()
    for i = 1, 10 do toolStorage:FireServer("Get", "Gun") end
end

local function fireGunAt(targetPart)
    if not targetPart or not plr.Character then return end
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    local root = plr.Character:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    local guns = {}
    for _, item in ipairs(plr.Backpack:GetChildren()) do
        if item.Name == "Gun" and item:FindFirstChild("shot") then table.insert(guns, item) end
    end
    if #guns == 0 then return end
    local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    local aimPos = targetPart.Position + (targetPart.Velocity * (0.15 + (ping * 0.5)))
    for _, gun in ipairs(guns) do
        if not (_G.killAllEnabled or _G.killAuraEnabled or _G.targetLockEnabled) then break end
        hum:EquipTool(gun)
        gun.Grip = CFrame.new((aimPos + Vector3.new(math.cos(tick()*12)*3, 0, 0)) - root.Position)
        task.spawn(function() for i=1,3 do gun.shot:FireServer(aimPos) end end)
    end
end

