-- [[ SimpleSpy Official - PC Optimized ]] --
task.spawn(function()
    local plr = game:GetService("Players").LocalPlayer
    local mouse = plr:GetMouse()
    local UserInputService = game:GetService("UserInputService")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local RunService = game:GetService("RunService")
    local CoreGui = game:GetService("CoreGui")

    -- ตรวจสอบการโหลดของ ToolStorage และ House Remote
    local toolStorage = ReplicatedStorage:WaitForChild("ToolStorage", 10):WaitForChild("ToolsStorage", 10)
    local HouseRemote = ReplicatedStorage:WaitForChild("House", 10)

    -- ลบ UI เก่า (ปรับปรุงการตรวจสอบให้ปลอดภัยขึ้นสำหรับ PC)
    for _, child in ipairs(CoreGui:GetChildren()) do
        if child.Name == "SimpleSpy_Official" then
            child:Destroy()
        end
    end

    --// Variables (Original Logic - NO CHANGES)
    local autoSellEnabled = false
    local killAuraEnabled = false
    local killAllEnabled = false
    local antiWarpEnabled = false
    local autoBuyLoop = false
    local noclipSwimRing = false 
    local antiCrashEnabled = false 
    local targetLockEnabled = false 
    local lockedTarget = nil 
    local lastValidPos = nil
    local gunVendorPos = Vector3.new(-76.84, 162.67, 231.24)

    local walkSpeedEnabled = false
    local jumpPowerEnabled = false
    local wsValue = 16
    local jpValue = 50

    --// --- [ METATABLE SYSTEM ] --- //--
    -- ปรับให้รองรับ Executor หลายค่ายบน PC
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    local set_readonly = setreadonly or make_readonly
    local set_writeable = setwriteable or make_writeable

    if set_writeable then set_writeable(mt, false) end

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "Kick" or method == "kick" then return nil end
        return oldNamecall(self, ...)
    end)
    
    if set_readonly then set_readonly(mt, true) end

    --// --- [ SYSTEM FUNCTIONS - ORIGINAL ] --- //--
    local function applyAntiCrash(p)
        if not antiCrashEnabled then return end
        local plrgui = p:WaitForChild("PlayerGui")
        local function cleanGui(gui)
            if antiCrashEnabled and gui.Name == "Announcement" then
                gui:Destroy()
            end
        end
        for _, g in ipairs(plrgui:GetChildren()) do cleanGui(g) end
        plrgui.ChildAdded:Connect(cleanGui)
    end

    local function stashAllGuns()
        for _, item in ipairs(plr.Backpack:GetChildren()) do
            if item.Name == "Gun" then 
                task.wait(0.05)
                toolStorage:FireServer("Save", "Gun") 
            end
        end
        if plr.Character then
            for _, item in ipairs(plr.Character:GetChildren()) do
                if item.Name == "Gun" then 
                    item.Parent = plr.Backpack
                    task.wait(0.05)
                    toolStorage:FireServer("Save", "Gun") 
                end
            end
        end
    end

    local function pullAllGuns()
        for i = 1, 10 do toolStorage:FireServer("Get", "Gun") end
    end

    local function fireGunAt(targetPart)
        if not targetPart or not plr.Character then return end
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        local root = plr.Character:FindFirstChild("HumanoidRootPart")
        if not hum or not root then return end
        
        local guns = {}
        for _, item in ipairs(plr.Backpack:GetChildren()) do
            if item.Name == "Gun" and item:FindFirstChild("shot") then table.insert(guns, item) end
        end
        if #guns == 0 then return end
        
        local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
        local predictionStrength = 0.15 + (ping * 0.5)
        local aimPos = targetPart.Position + (targetPart.Velocity * predictionStrength)
        
        for _, gun in ipairs(guns) do
            if not (killAllEnabled or killAuraEnabled or targetLockEnabled) then break end
            hum:EquipTool(gun)
            local angle = tick() * 12
            local orbit = Vector3.new(math.cos(angle) * 3, math.sin(angle) * 2, math.sin(angle) * 3)
            gun.Grip = CFrame.new((aimPos + orbit) - root.Position) * CFrame.Angles(math.rad(math.random(-180,180)), math.rad(math.random(-180,180)), 0)
            
            task.spawn(function()
                for i = 1, 3 do
                    gun.shot:FireServer(aimPos)
                end
            end)
        end
    end

    local function forceClick(targetPos)
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("ClickDetector") and v.Parent:IsA("BasePart") then
                if (v.Parent.Position - targetPos).Magnitude < 20 then
                    if fireclickdetector then
                        fireclickdetector(v)
                    end
                    return true
                end
            end
        end
        return false
    end

    --// --- [ UI SETUP - PC FIX ] --- //--
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SimpleSpy_Official"
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    -- แก้ไขจุดที่ทำให้รันไม่ติด: ตรวจสอบสิทธิ์ CoreGui
    local success, _ = pcall(function()
        ScreenGui.Parent = CoreGui
    end)
    if not success then
        ScreenGui.Parent = plr:WaitForChild("PlayerGui")
    end

    local TargetLabel = Instance.new("TextLabel")
    TargetLabel.Size = UDim2.new(0, 200, 0, 30)
    TargetLabel.Position = UDim2.new(0.5, -100, 0, 50)
    TargetLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    TargetLabel.BackgroundTransparency = 0.5
    TargetLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    TargetLabel.Text = "Target: None"
    TargetLabel.Font = Enum.Font.SpecialElite
    TargetLabel.TextSize = 14
    TargetLabel.Visible = false
    TargetLabel.Parent = ScreenGui
    Instance.new("UICorner", TargetLabel)

    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 240, 0, 320)
    MainFrame.Position = UDim2.new(0.5, -120, 0.5, -160)
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 0, 0)
    MainFrame.BorderSizePixel = 0
    MainFrame.Active = true
    MainFrame.Draggable = true 
    MainFrame.Parent = ScreenGui
    Instance.new("UICorner", MainFrame)

    local MiniButton = Instance.new("TextButton")
    MiniButton.Size = UDim2.new(0, 50, 0, 50)
    MiniButton.Position = UDim2.new(0.1, 0, 0.1, 0)
    MiniButton.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
    MiniButton.Text = "SS"
    MiniButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    MiniButton.Font = Enum.Font.SpecialElite
    MiniButton.TextSize = 20
    MiniButton.Visible = false
    MiniButton.Active = true
    MiniButton.Draggable = true
    MiniButton.Parent = ScreenGui
    Instance.new("UICorner", MiniButton)

    local MinBtn = Instance.new("TextButton")
    MinBtn.Size = UDim2.new(0, 25, 0, 25)
    MinBtn.Position = UDim2.new(1, -30, 0, 5)
    MinBtn.BackgroundColor3 = Color3.fromRGB(60, 0, 0)
    MinBtn.Text = "-"
    MinBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    MinBtn.Parent = MainFrame
    Instance.new("UICorner", MinBtn)

    MinBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = false
        MiniButton.Visible = true
    end)
    MiniButton.MouseButton1Click:Connect(function()
        MainFrame.Visible = true
        MiniButton.Visible = false
    end)

    mouse.Button1Down:Connect(function()
        if targetLockEnabled and mouse.Target then
            local model = mouse.Target:FindFirstAncestorOfClass("Model")
            if model and game.Players:GetPlayerFromCharacter(model) then
                local targetPlayer = game.Players:GetPlayerFromCharacter(model)
                if targetPlayer ~= plr then
                    lockedTarget = targetPlayer
                    TargetLabel.Text = "Target: " .. targetPlayer.Name
                    TargetLabel.Visible = true
                    task.delay(3, function() TargetLabel.Visible = false end)
                end
            end
        end
    end)

    local TabBar = Instance.new("ScrollingFrame")
    TabBar.Size = UDim2.new(1, 0, 0, 30)
    TabBar.Position = UDim2.new(0, 0, 0, 35)
    TabBar.BackgroundTransparency = 1
    TabBar.ScrollBarThickness = 0
    TabBar.CanvasSize = UDim2.new(1.5, 0, 0, 0)
    TabBar.Parent = MainFrame
    local TabList = Instance.new("UIListLayout", TabBar)
    TabList.FillDirection = Enum.FillDirection.Horizontal
    TabList.HorizontalAlignment = Enum.HorizontalAlignment.Left
    TabList.Padding = UDim.new(0, 5)

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 35)
    Title.Text = "SimpleSpy Official"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.SpecialElite
    Title.TextSize = 16
    Title.BackgroundTransparency = 1
    Title.Parent = MainFrame

    local Pages = {}
    local function CreatePage(name)
        local p = Instance.new("ScrollingFrame")
        p.Size = UDim2.new(1, -10, 1, -75)
        p.Position = UDim2.new(0, 5, 0, 70)
        p.BackgroundTransparency = 1
        p.ScrollBarThickness = 0
        p.Visible = false
        p.Parent = MainFrame
        Instance.new("UIListLayout", p).Padding = UDim.new(0, 5)
        Pages[name] = p
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 70, 1, 0)
        btn.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
        btn.Text = name
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        btn.Font = Enum.Font.SpecialElite
        btn.TextSize = 12
        btn.Parent = TabBar
        Instance.new("UICorner", btn)
        btn.MouseButton1Click:Connect(function()
            for _, page in pairs(Pages) do page.Visible = false end
            p.Visible = true
        end)
        return p
    end

    local function AddToggle(parent, txt, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 35)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        btn.Text = "[ OFF ] " .. txt
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        btn.Font = Enum.Font.SpecialElite
        btn.TextSize = 10
        btn.Parent = parent
        Instance.new("UICorner", btn)
        local state = false
        btn.MouseButton1Click:Connect(function()
            state = not state
            btn.Text = (state and "[ ON ] " or "[ OFF ] ") .. txt
            btn.BackgroundColor3 = state and Color3.fromRGB(100, 0, 0) or Color3.fromRGB(40, 40, 40)
            callback(state)
        end)
    end

    local function AddButton(parent, txt, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 35)
        btn.BackgroundColor3 = Color3.fromRGB(60, 0, 0)
        btn.Text = txt
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.SpecialElite
        btn.TextSize = 12
        btn.Parent = parent
        Instance.new("UICorner", btn)
        btn.MouseButton1Click:Connect(callback)
    end

    local function AddTextBox(parent, placeholder, callback)
        local box = Instance.new("TextBox")
        box.Size = UDim2.new(1, 0, 0, 30)
        box.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
        box.PlaceholderText = placeholder
        box.Text = ""
        box.TextColor3 = Color3.fromRGB(255, 255, 255)
        box.Font = Enum.Font.SpecialElite
        box.TextSize = 10
        box.Parent = parent
        Instance.new("UICorner", box)
        box.FocusLost:Connect(function()
            callback(box.Text)
        end)
    end

    local CombatPage = CreatePage("Combat")
    local FarmPage = CreatePage("Farm")
    local MiscPage = CreatePage("Misc")
    local MovePage = CreatePage("Move")
    CombatPage.Visible = true

    --// --- [ CONTENT - ORIGINAL LOGIC ] --- //--

    AddToggle(CombatPage, "KILL AURA (ELITE)", function(s)
        killAuraEnabled = s
        task.spawn(function()
            while killAuraEnabled do
                for _, enemy in ipairs(game.Players:GetPlayers()) do
                    if enemy ~= plr and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart") then
                        if enemy.Character:FindFirstChild("Humanoid") and enemy.Character.Humanoid.Health > 0 then
                            local dist = (plr.Character.HumanoidRootPart.Position - enemy.Character.HumanoidRootPart.Position).Magnitude
                            if dist <= 140 then fireGunAt(enemy.Character.HumanoidRootPart) end
                        end
                    end
                end
                task.wait(0.01)
            end
        end)
    end)

    AddToggle(CombatPage, "TARGET LOCK (CLICK)", function(s)
        targetLockEnabled = s
        if not s then lockedTarget = nil end
        task.spawn(function()
            while targetLockEnabled do
                if lockedTarget and lockedTarget.Character and lockedTarget.Character:FindFirstChild("HumanoidRootPart") then
                    if lockedTarget.Character.Humanoid.Health > 0 then fireGunAt(lockedTarget.Character.HumanoidRootPart) end
                end
                task.wait(0.01)
            end
        end)
    end)

    AddToggle(CombatPage, "KILL ALL (EXTREME)", function(s)
        killAllEnabled = s
        task.spawn(function()
            while killAllEnabled do
                for _, enemy in ipairs(game.Players:GetPlayers()) do
                    if not killAllEnabled then break end
                    if enemy ~= plr and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart") then
                        if enemy.Character.Humanoid.Health > 0 then fireGunAt(enemy.Character.HumanoidRootPart) end
                    end
                end
                task.wait(0.01)
            end
        end)
    end)

    AddButton(CombatPage, "GET GUNS", pullAllGuns)
    AddButton(CombatPage, "STASH GUNS", stashAllGuns)

    AddToggle(FarmPage, "AUTO SELL x500", function(s)
        autoSellEnabled = s
        task.spawn(function()
            while autoSellEnabled do
                for i = 1, 10 do task.defer(function() for i = 1, 500 do HouseRemote:FireServer("Sell") end end) end
                RunService.Heartbeat:Wait()
            end
        end)
    end)

    AddToggle(FarmPage, "AUTO BUY LOOP", function(s)
        autoBuyLoop = s
        task.spawn(function()
            while autoBuyLoop do
                if forceClick(gunVendorPos) then 
                    local checkTime = 0
                    repeat task.wait(0.05) checkTime = checkTime + 0.05 until plr.Backpack:FindFirstChild("Gun") or checkTime > 1
                    if plr.Backpack:FindFirstChild("Gun") then task.wait(0.05) toolStorage:FireServer("Save", "Gun") end
                end
                if not autoBuyLoop then pullAllGuns() break end
                pullAllGuns() task.wait(1.2)
            end
        end)
    end)

    AddToggle(MiscPage, "ANTI-WARP/CLAIM", function(s) antiWarpEnabled = s end)
    AddToggle(MiscPage, "ANTI-CRASH", function(s) if s then applyAntiCrash(plr) end end)
    AddToggle(MiscPage, "SWIMRING NOCLIP", function(s) noclipSwimRing = s end)

    AddToggle(MovePage, "SPEED WARP", function(s) walkSpeedEnabled = s end)
    AddTextBox(MovePage, "SPEED VALUE", function(t) wsValue = tonumber(t) or 16 end)
    AddToggle(MovePage, "HIGH JUMP", function(s) jumpPowerEnabled = s end)
    AddTextBox(MovePage, "JUMP VALUE", function(t) jpValue = tonumber(t) or 50 end)

    RunService.Heartbeat:Connect(function()
        local char = plr.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            if walkSpeedEnabled then hum.WalkSpeed = wsValue else hum.WalkSpeed = 16 end
            if jumpPowerEnabled then hum.JumpPower = jpValue hum.UseJumpPower = true else hum.JumpPower = 50 end
        end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if antiWarpEnabled and hrp and char.Humanoid.Health > 0 then
            if lastValidPos and (hrp.Position - lastValidPos.Position).Magnitude > 25 then
                hrp.CFrame = lastValidPos
                hrp.Velocity = Vector3.zero
                local gi = ReplicatedStorage:FindFirstChild("GetItemBack")
                if gi then gi:FireServer() end
            else lastValidPos = hrp.CFrame end
        end
        if noclipSwimRing then
            for _, v in ipairs(workspace:GetDescendants()) do
                if v.Name == "SwimRingPart2" and v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end)

    plr.CharacterAdded:Connect(function(char) if antiCrashEnabled then applyAntiCrash(plr) end end)
end)
